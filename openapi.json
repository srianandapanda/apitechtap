{"openapi":"3.0.1","info":{"title":"Aitechtap Core API","description":"REST API for auth, users, plans, AI chat, and payments. Most endpoints require JWT (Bearer token from POST /api/auth/login). Plan admin GET accepts JWT or Basic; plan admin POST/PUT require Basic only.","contact":{"name":"Aitechtap"},"version":"1.0"},"servers":[{"url":"http://localhost:8081","description":"Generated server url"}],"security":[{"bearerAuth":[]},{"basicAuth":[]}],"tags":[{"name":"AI","description":"Chat and career suggestions. JWT required."},{"name":"Payments","description":"Orders and Razorpay callback/webhook. Create order requires JWT."},{"name":"User","description":"With JWT: update profile. Without JWT: create user + profile (email/phone + password); no token returned."},{"name":"Auth","description":"Signup, login, logout, Google signup"}],"paths":{"/api/admin/plans/{id}":{"get":{"tags":["plan-admin-controller"],"operationId":"getById","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PlanResponse"}}}}}},"put":{"tags":["plan-admin-controller"],"summary":"Update plan","description":"Basic auth only. Plan UUID in path.","operationId":"update","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdatePlanRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PlanResponse"}}}}}}},"/api/users":{"post":{"tags":["User"],"summary":"Create or update profile","description":"Dynamic profile payload. With JWT: updates current user profile with any relevant fields. Without JWT: creates user + profile; include email or phone and password. Supports varied attributes for different user groups (student/professional).","operationId":"set","requestBody":{"description":"Dynamic JSON object; additional custom keys are accepted.","content":{"application/json":{"schema":{"type":"object","additionalProperties":true},"examples":{"Student profile sample":{"description":"Student profile sample","value":{"firstName":"Priya","lastName":"Sharma","dob":"2003-08-19","yearOfPassing":2025,"email":"priya.student@example.com","mobile":"9876543210","address":"Pune"}},"Professional profile sample":{"description":"Professional profile sample","value":{"firstName":"Rahul","lastName":"Verma","email":"rahul.pro@example.com","mobile":"9998887776","experienceYears":6,"currentRole":"Software Engineer","skills":["Java","Spring Boot","SQL"],"address":"Bengaluru"}}}}},"required":true},"responses":{"409":{"description":"User already exists","content":{"application/json":{"example":{"message":"User already registered with this email or phone"}}}},"400":{"description":"Validation error in dynamic payload","content":{"application/json":{}}},"200":{"description":"User profile created or updated","content":{"application/json":{"examples":{"Create profile success":{"description":"Create profile success","value":{"userId":"4b40e5fd-4194-4f11-ac58-ea0ea24f640c","message":"User created successfully. Use login to get token."}},"Update profile success":{"description":"Update profile success","value":{"userId":"4b40e5fd-4194-4f11-ac58-ea0ea24f640c","firstName":"Priya","targetRole":"Data Analyst"}}}}}}}}},"/api/payments/webhook/razorpay":{"post":{"tags":["Payments"],"summary":"Webhook","description":"Razorpay webhook. Header: X-Razorpay-Signature. Body: payment.captured/failed payload.","operationId":"razorpayWebhook","parameters":[{"name":"X-Razorpay-Signature","in":"header","required":false,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"type":"string"}}},"required":true},"responses":{"200":{"description":"OK"}}}},"/api/payments/orders":{"get":{"tags":["Payments"],"summary":"My orders","description":"List orders for current user. JWT required.","operationId":"myOrders","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/OrderEntity"}}}}}}},"post":{"tags":["Payments"],"summary":"Create order","description":"JWT required. userId is derived from token. Body must contain valid planId (UUID).","operationId":"createOrder","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateOrderRequest"}}},"required":true},"responses":{"400":{"description":"Invalid or unsupported planId","content":{"application/json":{}}},"500":{"description":"Unexpected server error while creating order","content":{"application/json":{"example":{"error":"Unable to create order"}}}},"401":{"description":"JWT missing or invalid","content":{"application/json":{"example":{"error":"Unauthorized"}}}},"200":{"description":"Order created successfully","content":{"application/json":{"example":{"orderId":"5a3cd087-9d38-4665-b22f-bf868ce4d08b","gatewayOrderId":"order_Q2tfFq7piVnE2A","amount":999.0,"currency":"INR","status":"PENDING_PAYMENT"}}}}}}},"/api/auth/signup":{"post":{"tags":["Auth"],"summary":"Signup","description":"Create user and credentials. Returns userId and message.","operationId":"signup","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SignupRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}},"/api/auth/signup/google":{"post":{"tags":["Auth"],"summary":"Signup with Google","description":"Sign up or sign in using Google ID token.","operationId":"signupGoogle","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GoogleSignupRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}},"/api/auth/logout":{"post":{"tags":["Auth"],"summary":"Logout","description":"Revoke JWT. Send Bearer token in Authorization header.","operationId":"logout","parameters":[{"name":"Authorization","in":"header","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"string"}}}}}}}},"/api/auth/login":{"post":{"tags":["Auth"],"summary":"Login","description":"Returns JWT token and expiresIn. Use token as Bearer for other APIs.","operationId":"login","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/LoginRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}},"/api/ai/chat":{"post":{"tags":["AI"],"summary":"Chat","description":"Dynamic chat payload. Can include any question/context fields. If body is empty, API starts a new interaction.","operationId":"chat","requestBody":{"description":"Dynamic JSON payload; commonly includes message.","content":{"application/json":{"schema":{"type":"object","additionalProperties":true},"examples":{"Simple chat question":{"description":"Simple chat question","value":{"message":"I am a BTech final year student. Which career path suits me?"}},"Question with extra context":{"description":"Question with extra context","value":{"message":"I have 4 years of Java experience and want to move to AI. What should I learn first?","userType":"professional","targetRole":"AI Engineer","preferredTimelineMonths":"6"}}}}}},"responses":{"400":{"description":"Invalid chat payload or processing issue","content":{"application/json":{"example":{"error":"message is required"}}}},"200":{"description":"AI response generated","content":{"application/json":{"examples":{"Chat success sample":{"description":"Chat success sample","value":{"question":"I am a BTech final year student. Which career path suits me?","answer":"Based on your profile, start with Data Analyst and Backend Developer tracks.","nextStep":"Share your interests and strongest subjects."}}}}}},"401":{"description":"JWT missing or invalid","content":{"application/json":{"example":{"error":"Unauthorized"}}}}}}},"/api/admin/plans":{"get":{"tags":["plan-admin-controller"],"summary":"List plans","description":"JWT or Basic. Query: planType (FREE/PRO/ELITE), activeOnly.","operationId":"list","parameters":[{"name":"planType","in":"query","required":false,"schema":{"type":"string","enum":["FREE","PRO","ELITE"]}},{"name":"activeOnly","in":"query","required":false,"schema":{"type":"boolean","default":false}}],"responses":{"200":{"description":"OK","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PlanResponse"}}}}}}},"post":{"tags":["plan-admin-controller"],"summary":"Create plan","description":"Basic auth only. planType: FREE, PRO, ELITE.","operationId":"create","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreatePlanRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PlanResponse"}}}}}}},"/api/users/{userId}":{"get":{"tags":["User"],"summary":"Get my profile","description":"Get current user data. Path userId must match JWT.","operationId":"get","parameters":[{"name":"userId","in":"path","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}},"/api/payments/orders/{orderId}":{"get":{"tags":["Payments"],"summary":"Get order by ID","description":"JWT required. Order UUID in path.","operationId":"getOrder","parameters":[{"name":"orderId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/OrderEntity"}}}}}}},"/api/payments/callback/razorpay":{"get":{"tags":["Payments"],"summary":"Payment callback","description":"Razorpay redirect. No JWT. Query: razorpay_payment_id, razorpay_order_id.","operationId":"razorpayCallback","parameters":[{"name":"razorpay_payment_id","in":"query","required":false,"schema":{"type":"string"}},{"name":"razorpay_order_id","in":"query","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK"}}}},"/api/ai/career-suggestions":{"get":{"tags":["AI"],"summary":"Get career suggestions","description":"Returns conversation and AI suggestions for current user.","operationId":"getCareerSuggestions","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}}},"components":{"schemas":{"UpdatePlanRequest":{"type":"object","properties":{"planType":{"type":"string","enum":["FREE","PRO","ELITE"]},"price":{"type":"number"},"currency":{"type":"string"},"isActive":{"type":"boolean"},"metadata":{"type":"object","additionalProperties":{"type":"object"}},"actionCodes":{"type":"array","items":{"type":"string"}},"featureCodes":{"type":"array","items":{"type":"string"}}}},"PlanResponse":{"type":"object","properties":{"id":{"type":"string","format":"uuid"},"planType":{"type":"string","enum":["FREE","PRO","ELITE"]},"price":{"type":"number"},"currency":{"type":"string"},"isActive":{"type":"boolean"},"metadata":{"type":"object","additionalProperties":{"type":"object"}},"actionCodes":{"type":"array","items":{"type":"string"}},"featureCodes":{"type":"array","items":{"type":"string"}},"createdAt":{"type":"string","format":"date-time"},"updatedAt":{"type":"string","format":"date-time"}}},"CreateOrderRequest":{"required":["planId"],"type":"object","properties":{"planId":{"type":"string","description":"Plan identifier selected by user","format":"uuid","example":"5c84a2be-4b0d-4a74-a34d-cf955ec1c2a3"}}},"SignupRequest":{"required":["password"],"type":"object","properties":{"email":{"type":"string"},"phone":{"type":"string"},"password":{"type":"string"}}},"GoogleSignupRequest":{"type":"object","properties":{"idToken":{"type":"string"}}},"LoginRequest":{"required":["password"],"type":"object","properties":{"email":{"type":"string"},"password":{"type":"string"},"mobile_number":{"type":"string"}}},"CreatePlanRequest":{"required":["planType"],"type":"object","properties":{"planType":{"type":"string","enum":["FREE","PRO","ELITE"]},"price":{"type":"number"},"currency":{"type":"string"},"isActive":{"type":"boolean"},"metadata":{"type":"object","additionalProperties":{"type":"object"}},"actionCodes":{"type":"array","items":{"type":"string"}},"featureCodes":{"type":"array","items":{"type":"string"}}}},"OrderEntity":{"type":"object","properties":{"id":{"type":"string","format":"uuid"},"userId":{"type":"string"},"planId":{"type":"string","format":"uuid"},"status":{"type":"string","enum":["CREATED","PENDING_PAYMENT","PAYMENT_INITIATED","PAYMENT_SUCCESS","COMPLETED","FAILED","CANCELLED"]},"amount":{"type":"number"},"currency":{"type":"string"},"gatewayOrderId":{"type":"string"},"createdAt":{"type":"string","format":"date-time"},"updatedAt":{"type":"string","format":"date-time"}}}},"securitySchemes":{"bearerAuth":{"type":"http","description":"Paste the JWT token from POST /api/auth/login (value only; 'Bearer ' is added automatically).","scheme":"bearer","bearerFormat":"JWT"},"basicAuth":{"type":"http","description":"Plan admin: app.plan.admin.username / password","scheme":"basic"}}}}